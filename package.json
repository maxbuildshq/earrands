{
  "name": "earrands",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && rm -rf dist && vite build && cp dist/app/index.html dist/index.html",
    "deploy": "npm run build && npx wrangler deploy",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "parse-artists": "tsx --env-file=.env.local scripts/parse-artists.ts",
    "ingest": "tsx --env-file=.env.local scripts/ingest.ts",
    "notify": "tsx --env-file=.env.local scripts/notify.ts",
    "enrich": "tsx --env-file=.env.local scripts/enrich-artists.ts"
  },
  "dependencies": {
    "@fontsource/barlow-condensed": "^5.2.8",
    "@fontsource/space-mono": "^5.2.9",
    "@posthog/react": "^1.9.1",
    "@supabase/supabase-js": "^2.105.4",
    "@tanstack/react-query": "^5.100.10",
    "posthog-js": "^1.376.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.1",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/cheerio": "^0.22.35",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "chalk": "^5.6.2",
    "cheerio": "^1.2.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "playwright": "^1.60.0",
    "resend": "^6.12.4",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.3",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.7"
  }
}
