VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Server-side only (scripts: ingest, parse-artists, notify) — never expose in the browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Timetable-drop notifier (scripts/notify.ts)
RESEND_API_KEY=your-resend-api-key
NOTIFY_FROM_EMAIL=earrands <noreply@yourdomain.com>
APP_BASE_URL=https://earrands.app/app

# Artist enrichment (scripts/enrich-artists.ts)
BRAVE_API_KEY=your-brave-search-api-key
DISCOGS_CONSUMER_KEY=your-discogs-consumer-key
DISCOGS_CONSUMER_SECRET=your-discogs-consumer-secret
# Optional: Google Custom Search (unused by default, kept as fallback)
# GOOGLE_API_KEY=your-google-api-key
# GOOGLE_CSE_ID=your-custom-search-engine-id
